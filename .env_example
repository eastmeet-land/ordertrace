# ============================================
# OrderTrace 환경 설정
# 사용법: 이 파일을 복사하여 .env로 생성
# cp .env.example .env
# ============================================

# APPLICATION
APP_PORT=18080
SPRING_PROFILE=local
# docker 프로필로 실행 시 EFK 로그 전송 활성화
# SPRING_PROFILE=docker

# DB (docker-compose로 실행되는 PostgreSQL)
DB_HOST=localhost
DB_PORT=15432
DB_NAME=ordertrace
DB_USERNAME=ordertrace
DB_PASSWORD=ordertrace

# MONITORING
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
KIBANA_BASE_URL=http://localhost:5601

# ============================================
# 실행 방법
# ============================================
# 1. 인프라 실행: docker-compose up -d
# 2. 앱 실행 (local): ./gradlew bootRun
# 3. 앱 실행 (EFK 연동): ./gradlew bootRun --args='--spring.profiles.active=docker'
# 4. Swagger: http://localhost:18080/swagger-ui.html
# 5. Kibana: http://localhost:5601